model SearchDemandQueue {
  id              String    @id @default(uuid())
  plate           String?
  vin             String?
  resultState     String    @default("pending_enrichment") @map("result_state")
  timesRequested  Int       @default(1)                   @map("times_requested")
  lastRequestedAt DateTime  @default(now())               @map("last_requested_at")
  enrichedAt      DateTime?                               @map("enriched_at")
  createdAt       DateTime  @default(now())               @map("created_at")

  @@map("search_demand_queue")
}
