generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String         @unique
  role             UserRole       @default(user)
  createdAt        DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime?      @updatedAt @map("updated_at") @db.Timestamptz(6)
  adminSettings    AdminSetting[]
  reviewedContribs Contribution[] @relation("contributionReviewer")
  contributions    Contribution[]
  corConsents      CorConsent[]
  creditLedger     CreditLedger[]
  ocrScans         OcrScan[]
  payments         Payment[]
  profile          Profile?
  reportUnlocks    ReportUnlock[]
  stolenReports    StolenReport[] @relation("stolenReporter")
  reviewedStolen   StolenReport[] @relation("stolenReviewer")
  wallet           Wallet?

  @@map("users")
}

model Profile {
  userId        String    @id @map("user_id") @db.Uuid
  displayName   String?   @map("display_name")
  phone         String?
  avatarUrl     String?   @map("avatar_url")
  county        String?
  preferredLang String?   @default("en") @map("preferred_lang")
  updatedAt     DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("profiles")
}

model Vehicle {
  vin                 String         @id
  chassisNumber       String?        @map("chassis_number")
  make                String?
  model               String?
  year                Int?
  engineCc            Int?           @map("engine_cc")
  fuelType            String?        @map("fuel_type")
  transmission        String?
  bodyType            String?        @map("body_type")
  color               String?
  countryOfOrigin     String?        @map("country_of_origin")
  importCountry       String?        @map("import_country")
  isImported          Boolean?       @default(false) @map("is_imported")
  japanAuctionGrade   String?        @map("japan_auction_grade")
  japanAuctionMileage Int?           @map("japan_auction_mileage")
  kraPin              String?        @map("kra_pin")
  ntsaId              String?        @map("ntsa_id")
  inspectionStatus    InspStatus?    @map("inspection_status")
  lastInspectionDate  DateTime?      @map("last_inspection_date") @db.Date
  caveatStatus        CaveatSt?      @map("caveat_status")
  psvLicensed         Boolean?       @default(false) @map("psv_licensed")
  ntsaCorVerified     Boolean?       @default(false) @map("ntsa_cor_verified")
  ntsaCorDate         DateTime?      @map("ntsa_cor_date") @db.Timestamptz(6)
  ntsaCorSource       CorSource?     @map("ntsa_cor_source")
  createdAt           DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?      @updatedAt @map("updated_at") @db.Timestamptz(6)
  contributions       Contribution[]
  plateVinMaps        PlateVinMap[]
  reports             Report[]
  stolenReports       StolenReport[]
  vehicleEvents       VehicleEvent[]

  @@map("vehicles")
}

model PlateVinMap {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plate        String
  plateDisplay String?    @map("plate_display")
  vin          String
  confidence   Float?     @default(0.5)
  source       PvmSource?
  verifiedAt   DateTime?  @map("verified_at") @db.Timestamptz(6)
  createdAt    DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  vehicle      Vehicle    @relation(fields: [vin], references: [vin], onDelete: Cascade, onUpdate: NoAction)

  @@index([plate], map: "idx_pvm_plate")
  @@index([vin], map: "idx_pvm_vin")
  @@map("plate_vin_map")
}

model Report {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vin            String
  status         ReportStatus?   @default(draft)
  riskScore      Int?            @map("risk_score")
  riskLevel      RiskLevel?      @map("risk_level")
  recommendation Recommendation?
  sourcesChecked Int?            @default(0) @map("sources_checked")
  recordsFound   Int?            @default(0) @map("records_found")
  generatedAt    DateTime?       @map("generated_at") @db.Timestamptz(6)
  updatedAt      DateTime?       @updatedAt @map("updated_at") @db.Timestamptz(6)
  ledgerEntries  CreditLedger[]
  sections       ReportSection[]
  unlocks        ReportUnlock[]
  vehicle        Vehicle         @relation(fields: [vin], references: [vin], onDelete: Cascade, onUpdate: NoAction)

  @@index([vin], map: "idx_reports_vin")
  @@map("reports")
}

model ReportSection {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId    String      @map("report_id") @db.Uuid
  sectionType SectionType @map("section_type")
  data        Json?
  isLocked    Boolean?    @default(true) @map("is_locked")
  recordCount Int?        @default(0) @map("record_count")
  dataStatus  DataStatus? @default(not_checked) @map("data_status")
  updatedAt   DateTime?   @updatedAt @map("updated_at") @db.Timestamptz(6)
  report      Report      @relation(fields: [reportId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("report_sections")
}

model ReportUnlock {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  reportId     String    @map("report_id") @db.Uuid
  creditsSpent Int       @map("credits_spent")
  unlockedAt   DateTime? @default(now()) @map("unlocked_at") @db.Timestamptz(6)
  report       Report    @relation(fields: [reportId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user         User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, reportId])
  @@map("report_unlocks")
}

model VehicleEvent {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vin        String
  eventType  EventType    @map("event_type")
  eventDate  DateTime     @map("event_date") @db.Date
  country    String?      @default("KE")
  county     String?
  source     EventSource?
  sourceRef  String?      @map("source_ref")
  confidence Float?       @default(0.8)
  metadata   Json?
  createdAt  DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  vehicle    Vehicle      @relation(fields: [vin], references: [vin], onDelete: Cascade, onUpdate: NoAction)

  @@index([vin], map: "idx_events_vin")
  @@index([eventDate], map: "idx_events_date")
  @@map("vehicle_events")
}

model StolenReport {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plate            String
  plateDisplay     String?       @map("plate_display")
  vin              String?
  reporterUserId   String?       @map("reporter_user_id") @db.Uuid
  reporterType     ReporterType? @map("reporter_type")
  dateStolen       DateTime      @map("date_stolen") @db.Date
  countyStolen     String        @map("county_stolen")
  townStolen       String        @map("town_stolen")
  policeObNumber   String?       @map("police_ob_number")
  policeStation    String?       @map("police_station")
  carColor         String        @map("car_color")
  identifyingMarks String?       @map("identifying_marks")
  photoUrls        String[]      @map("photo_urls")
  contactPhone     String?       @map("contact_phone")
  contactEmail     String?       @map("contact_email")
  status           StolenStatus? @default(pending)
  isObVerified     Boolean?      @default(false) @map("is_ob_verified")
  adminNote        String?       @map("admin_note")
  reviewedBy       String?       @map("reviewed_by") @db.Uuid
  reviewedAt       DateTime?     @map("reviewed_at") @db.Timestamptz(6)
  recoveryDate     DateTime?     @map("recovery_date") @db.Date
  recoveryCounty   String?       @map("recovery_county")
  recoveryNotes    String?       @map("recovery_notes")
  createdAt        DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  reporter         User?         @relation("stolenReporter", fields: [reporterUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewer         User?         @relation("stolenReviewer", fields: [reviewedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle          Vehicle?      @relation(fields: [vin], references: [vin], onDelete: NoAction, onUpdate: NoAction)

  @@index([plate], map: "idx_stolen_plate")
  @@index([vin], map: "idx_stolen_vin")
  @@index([status], map: "idx_stolen_status")
  @@map("stolen_reports")
}

model Wallet {
  userId    String    @id @map("user_id") @db.Uuid
  balance   Int       @default(0)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("wallets")
}

model CreditLedger {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String     @map("user_id") @db.Uuid
  type          LedgerType
  creditsDelta  Int        @map("credits_delta")
  balanceBefore Int        @map("balance_before")
  balanceAfter  Int        @map("balance_after")
  source        String?
  reportId      String?    @map("report_id") @db.Uuid
  txRef         String?    @map("tx_ref")
  metadata      Json?
  createdAt     DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  report        Report?    @relation(fields: [reportId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user          User       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId], map: "idx_ledger_user")
  @@map("credit_ledger")
}

model PaymentProvider {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      ProviderSlug @unique
  isEnabled Boolean?     @default(false) @map("is_enabled")
  config    Json?
  updatedAt DateTime?    @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("payment_providers")
}

model Payment {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  provider     String
  amount       Int
  currency     String?    @default("KES")
  credits      Int
  status       PayStatus? @default(pending)
  providerRef  String?    @unique @map("provider_ref")
  providerMeta Json?      @map("provider_meta")
  createdAt    DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("payments")
}

model Contribution {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vin                 String
  userId              String?        @map("user_id") @db.Uuid
  type                ContribType
  title               String
  description         String?
  data                Json?
  evidenceUrls        String[]       @map("evidence_urls")
  verificationDocUrls String[]       @map("verification_doc_urls")
  status              ContribStatus? @default(pending)
  adminNote           String?        @map("admin_note")
  reviewedBy          String?        @map("reviewed_by") @db.Uuid
  reviewedAt          DateTime?      @map("reviewed_at") @db.Timestamptz(6)
  confidenceScore     Float?         @map("confidence_score")
  createdAt           DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  reviewer            User?          @relation("contributionReviewer", fields: [reviewedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                User?          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle             Vehicle        @relation(fields: [vin], references: [vin], onDelete: NoAction, onUpdate: NoAction)

  @@map("contributions")
}

model CorConsent {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  vin          String
  plate        String
  consentedAt  DateTime? @default(now()) @map("consented_at") @db.Timestamptz(6)
  pdfProcessed Boolean?  @default(false) @map("pdf_processed")
  processedAt  DateTime? @map("processed_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("cor_consents")
}

model OcrScan {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String?    @map("user_id") @db.Uuid
  imageUrl         String     @map("image_url")
  documentType     DocType?   @map("document_type")
  rawOcrResult     Json?      @map("raw_ocr_result")
  extractedPlate   String?    @map("extracted_plate")
  extractedVin     String?    @map("extracted_vin")
  extractedChassis String?    @map("extracted_chassis")
  confidence       Float?
  confirmedValue   String?    @map("confirmed_value")
  source           OcrSource?
  createdAt        DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User?      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("ocr_scans")
}

model ScraperJob {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source       ScraperSrc
  status       JobStatus?       @default(queued)
  trigger      JobTrigger?
  itemsFound   Int?             @default(0) @map("items_found")
  itemsStored  Int?             @default(0) @map("items_stored")
  itemsSkipped Int?             @default(0) @map("items_skipped")
  startedAt    DateTime?        @map("started_at") @db.Timestamptz(6)
  completedAt  DateTime?        @map("completed_at") @db.Timestamptz(6)
  errorLog     String?          @map("error_log")
  createdAt    DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  rawData      ScraperDataRaw[]

  @@map("scraper_jobs")
}

model ScraperDataRaw {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId       String     @map("job_id") @db.Uuid
  source      String
  rawData     Json       @map("raw_data")
  vin         String?
  plate       String?
  processed   Boolean?   @default(false)
  processedAt DateTime?  @map("processed_at") @db.Timestamptz(6)
  createdAt   DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  job         ScraperJob @relation(fields: [jobId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([vin], map: "idx_raw_vin")
  @@index([plate], map: "idx_raw_plate")
  @@index([processed], map: "idx_raw_processed")
  @@map("scraper_data_raw")
}

model AdminSetting {
  key         String    @id
  value       Json
  description String?
  updatedBy   String?   @map("updated_by") @db.Uuid
  updatedAt   DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User?     @relation(fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("admin_settings")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model admin_config {
  key        String   @id
  value      Json
  updated_by String?  @db.Uuid
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model raw_records {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vin             String?
  plate           String?
  source          String
  source_id       String?
  raw_json        Json?
  normalised_json Json?
  confidence      Decimal?  @default(0) @db.Decimal(3, 2)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([plate])
  @@index([source])
  @@index([vin])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model data_sources {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  type            String
  parser_type     String
  credentials_enc String?
  schedule        String?
  enabled         Boolean   @default(true)
  last_run_at     DateTime? @db.Timestamptz(6)
  last_status     String?
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @db.Timestamptz(6)
}

