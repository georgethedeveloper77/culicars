generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Profile {
  userId                  String    @id @db.Uuid
  displayName             String?
  phone                   String?
  avatarUrl               String?
  county                  String?
  preferred_lang          String?   @default("en")
  preferred_lat           Float?
  preferred_lng           Float?
  preferred_location_name String?
  updated_at              DateTime? @db.Timestamptz(6)
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String          @unique
  role          user_role       @default(user)
  credits       Int             @default(0)
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?       @db.Timestamptz(6)
  Profile       Profile?
  user_vehicles user_vehicles[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model admin_config {
  key        String   @id
  value      Json
  updated_by String?  @db.Uuid
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model admin_settings {
  key         String    @id
  value       Json
  description String?
  updated_by  String?   @db.Uuid
  updated_at  DateTime? @db.Timestamptz(6)
  users       users?    @relation(fields: [updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model contributions {
  id                                     String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vin                                    String
  user_id                                String?        @db.Uuid
  type                                   ContribType
  title                                  String
  description                            String?
  data                                   Json?
  evidence_urls                          String[]
  verification_doc_urls                  String[]
  status                                 ContribStatus? @default(pending)
  admin_note                             String?
  reviewed_by                            String?        @db.Uuid
  reviewed_at                            DateTime?      @db.Timestamptz(6)
  confidence_score                       Float?
  created_at                             DateTime?      @default(now()) @db.Timestamptz(6)
  plate                                  String?
  users_contributions_reviewed_byTousers users?         @relation("contributions_reviewed_byTousers", fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_contributions_user_idTousers     users?         @relation("contributions_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicles                               vehicles       @relation(fields: [vin], references: [vin], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cor_consents {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  vin           String
  plate         String
  consented_at  DateTime? @default(now()) @db.Timestamptz(6)
  pdf_processed Boolean?  @default(false)
  processed_at  DateTime? @db.Timestamptz(6)
  users         users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model credit_ledger {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String     @db.Uuid
  type           LedgerType
  credits_delta  Int
  balance_before Int
  balance_after  Int
  source         String?
  report_id      String?    @db.Uuid
  tx_ref         String?
  metadata       Json?
  created_at     DateTime?  @default(now()) @db.Timestamptz(6)
  provider_ref   String?    @unique
  reports        reports?   @relation(fields: [report_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_ledger_user")
}

model credit_transactions {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String          @db.Uuid
  amount         Int
  type           String
  provider       String?
  provider_ref   String?         @unique
  pack_id        String?
  report_id      String?         @db.Uuid
  status         String          @default("pending")
  meta_json      Json?
  created_at     DateTime        @default(now()) @db.Timestamptz(6)
  vehicle_report vehicle_report? @relation(fields: [report_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status], map: "idx_credit_tx_status")
  @@index([user_id], map: "idx_credit_tx_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model data_sources {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  type            String
  parser_type     String
  credentials_enc String?
  schedule        String?
  enabled         Boolean   @default(true)
  last_run_at     DateTime? @db.Timestamptz(6)
  last_status     String?
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ocr_scans {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String?    @db.Uuid
  image_url         String
  document_type     DocType?
  raw_ocr_result    Json?
  extracted_plate   String?
  extracted_vin     String?
  extracted_chassis String?
  confidence        Float?
  confirmed_value   String?
  source            OcrSource?
  created_at        DateTime?  @default(now()) @db.Timestamptz(6)
  users             users?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payment_providers {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       ProviderSlug @unique
  is_enabled Boolean?     @default(false)
  config     Json?
  updated_at DateTime?    @db.Timestamptz(6)
  platform   String?      @default("both")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payments {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String     @db.Uuid
  provider      String
  amount        Int
  currency      String?    @default("KES")
  credits       Int
  status        PayStatus? @default(pending)
  provider_ref  String?    @unique
  provider_meta Json?
  created_at    DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?  @db.Timestamptz(6)
  users         users      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model plate_vin_map {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plate         String
  plate_display String?
  vin           String
  confidence    Float?     @default(0.5)
  source        PvmSource?
  verified_at   DateTime?  @db.Timestamptz(6)
  created_at    DateTime?  @default(now()) @db.Timestamptz(6)
  vehicles      vehicles   @relation(fields: [vin], references: [vin], onDelete: Cascade, onUpdate: NoAction)

  @@index([plate], map: "idx_pvm_plate")
  @@index([vin], map: "idx_pvm_vin")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  user_id        String    @id @db.Uuid
  display_name   String?
  phone          String?
  avatar_url     String?
  county         String?
  preferred_lang String?   @default("en")
  updated_at     DateTime? @db.Timestamptz(6)
  users          users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model raw_records {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vin             String?
  plate           String?
  source          String
  source_id       String?
  raw_json        Json?
  normalised_json Json?
  confidence      Decimal?  @default(0) @db.Decimal(3, 2)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([plate], map: "idx_raw_records_plate")
  @@index([vin], map: "idx_raw_records_vin")
  @@index([plate])
  @@index([source])
  @@index([vin])
}

model report_access {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_id      String         @db.Uuid
  user_id        String         @db.Uuid
  accessed_at    DateTime       @default(now()) @db.Timestamptz(6)
  vehicle_report vehicle_report @relation(fields: [report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([report_id, user_id], map: "uq_report_access_report_user")
  @@index([report_id, user_id], map: "idx_report_access_report_user")
  @@index([user_id], map: "idx_report_access_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model report_sections {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_id    String      @db.Uuid
  section_type SectionType
  data         Json?
  is_locked    Boolean?    @default(true)
  record_count Int?        @default(0)
  data_status  DataStatus? @default(not_checked)
  updated_at   DateTime?   @db.Timestamptz(6)
  reports      reports     @relation(fields: [report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model report_unlock {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String         @db.Uuid
  report_id      String         @db.Uuid
  unlocked_at    DateTime       @default(now()) @db.Timestamptz(6)
  vehicle_report vehicle_report @relation(fields: [report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, report_id])
  @@index([user_id], map: "idx_report_unlock_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model report_unlocks {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  report_id     String    @db.Uuid
  credits_spent Int
  unlocked_at   DateTime? @default(now()) @db.Timestamptz(6)
  reports       reports   @relation(fields: [report_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, report_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reports {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vin             String
  status          ReportStatus?     @default(draft)
  risk_score      Int?
  risk_level      RiskLevel?
  recommendation  Recommendation?
  sources_checked Int?              @default(0)
  records_found   Int?              @default(0)
  generated_at    DateTime?         @db.Timestamptz(6)
  updated_at      DateTime?         @db.Timestamptz(6)
  result_state    result_state?     @default(pending_enrichment)
  credit_ledger   credit_ledger[]
  report_sections report_sections[]
  report_unlocks  report_unlocks[]
  vehicles        vehicles          @relation(fields: [vin], references: [vin], onDelete: Cascade, onUpdate: NoAction)

  @@index([vin], map: "idx_reports_vin")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model scraper_data_raw {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id       String       @db.Uuid
  source       String
  raw_data     Json
  vin          String?
  plate        String?
  processed    Boolean?     @default(false)
  processed_at DateTime?    @db.Timestamptz(6)
  created_at   DateTime?    @default(now()) @db.Timestamptz(6)
  scraper_jobs scraper_jobs @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([plate], map: "idx_raw_plate")
  @@index([processed], map: "idx_raw_processed")
  @@index([vin], map: "idx_raw_vin")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model scraper_jobs {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source           ScraperSrc
  status           JobStatus?         @default(queued)
  trigger          JobTrigger?
  items_found      Int?               @default(0)
  items_stored     Int?               @default(0)
  items_skipped    Int?               @default(0)
  started_at       DateTime?          @db.Timestamptz(6)
  completed_at     DateTime?          @db.Timestamptz(6)
  error_log        String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  scraper_data_raw scraper_data_raw[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model search_demand_queue {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plate             String?
  vin               String?
  result_state      String    @default("pending_enrichment")
  times_requested   Int       @default(1)
  last_requested_at DateTime  @default(now()) @db.Timestamptz(6)
  enriched_at       DateTime? @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)

  @@index([last_requested_at(sort: Desc)], map: "idx_sdq_last_req")
  @@index([result_state], map: "idx_sdq_state")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model stolen_reports {
  id                                           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plate                                        String
  plate_display                                String?
  vin                                          String?
  reporter_user_id                             String?       @db.Uuid
  reporter_type                                ReporterType?
  date_stolen                                  DateTime      @db.Date
  county_stolen                                String
  town_stolen                                  String
  police_ob_number                             String?
  police_station                               String?
  car_color                                    String
  identifying_marks                            String?
  photo_urls                                   String[]
  contact_phone                                String?
  contact_email                                String?
  status                                       StolenStatus? @default(pending)
  is_ob_verified                               Boolean?      @default(false)
  admin_note                                   String?
  reviewed_by                                  String?       @db.Uuid
  reviewed_at                                  DateTime?     @db.Timestamptz(6)
  recovery_date                                DateTime?     @db.Date
  recovery_county                              String?
  recovery_notes                               String?
  created_at                                   DateTime?     @default(now()) @db.Timestamptz(6)
  users_stolen_reports_reporter_user_idTousers users?        @relation("stolen_reports_reporter_user_idTousers", fields: [reporter_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_stolen_reports_reviewed_byTousers      users?        @relation("stolen_reports_reviewed_byTousers", fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicles                                     vehicles?     @relation(fields: [vin], references: [vin], onDelete: NoAction, onUpdate: NoAction)

  @@index([plate], map: "idx_stolen_plate")
  @@index([status], map: "idx_stolen_status")
  @@index([vin], map: "idx_stolen_vin")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_vehicles {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String   @db.Uuid
  plate             String?
  vin               String?
  relationship_type String   @default("owner")
  nickname          String?
  alert_radius_km   Int?     @default(10)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)
  User              User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, plate, vin], map: "user_vehicles_unique")
  @@index([plate], map: "idx_user_vehicles_plate")
  @@index([user_id], map: "idx_user_vehicles_user_id")
  @@index([vin], map: "idx_user_vehicles_vin")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                                                    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                                 String           @unique
  role                                                  UserRole         @default(user)
  created_at                                            DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at                                            DateTime?        @db.Timestamptz(6)
  admin_settings                                        admin_settings[]
  contributions_contributions_reviewed_byTousers        contributions[]  @relation("contributions_reviewed_byTousers")
  contributions_contributions_user_idTousers            contributions[]  @relation("contributions_user_idTousers")
  cor_consents                                          cor_consents[]
  credit_ledger                                         credit_ledger[]
  ocr_scans                                             ocr_scans[]
  payments                                              payments[]
  profiles                                              profiles?
  report_access                                         report_access[]
  report_unlocks                                        report_unlocks[]
  stolen_reports_stolen_reports_reporter_user_idTousers stolen_reports[] @relation("stolen_reports_reporter_user_idTousers")
  stolen_reports_stolen_reports_reviewed_byTousers      stolen_reports[] @relation("stolen_reports_reviewed_byTousers")
  wallets                                               wallets?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model vehicle_events {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vin        String
  event_type EventType
  event_date DateTime     @db.Date
  country    String?      @default("KE")
  county     String?
  source     EventSource?
  source_ref String?
  confidence Float?       @default(0.8)
  metadata   Json?
  created_at DateTime?    @default(now()) @db.Timestamptz(6)
  vehicles   vehicles     @relation(fields: [vin], references: [vin], onDelete: Cascade, onUpdate: NoAction)

  @@index([event_date], map: "idx_events_date")
  @@index([vin], map: "idx_events_vin")
}

model vehicle_report {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vin                 String
  plate               String?
  state               String                @default("pending_enrichment")
  risk_score          Int                   @default(0)
  risk_level          String                @default("low")
  risk_flags          Json                  @default("[]")
  sections_json       Json                  @default("{}")
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  credit_transactions credit_transactions[]
  report_access       report_access[]
  report_unlock       report_unlock[]

  @@index([plate], map: "idx_vehicle_report_plate")
  @@index([state], map: "idx_vehicle_report_state")
  @@index([vin], map: "idx_vehicle_report_vin")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model vehicles {
  vin                   String           @id
  chassis_number        String?
  make                  String?
  model                 String?
  year                  Int?
  engine_cc             Int?
  fuel_type             String?
  transmission          String?
  body_type             String?
  color                 String?
  country_of_origin     String?
  import_country        String?
  is_imported           Boolean?         @default(false)
  japan_auction_grade   String?
  japan_auction_mileage Int?
  kra_pin               String?
  ntsa_id               String?
  inspection_status     InspStatus?
  last_inspection_date  DateTime?        @db.Date
  caveat_status         CaveatSt?
  psv_licensed          Boolean?         @default(false)
  ntsa_cor_verified     Boolean?         @default(false)
  ntsa_cor_date         DateTime?        @db.Timestamptz(6)
  ntsa_cor_source       CorSource?
  created_at            DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?        @db.Timestamptz(6)
  contributions         contributions[]
  plate_vin_map         plate_vin_map[]
  reports               reports[]
  stolen_reports        stolen_reports[]
  vehicle_events        vehicle_events[]
