/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model wallets {
  user_id    String    @id @db.Uuid
  balance    Int       @default(0)
  updated_at DateTime? @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model watch_alerts {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plate           String?
  vin             String?
  type            watch_alert_type
  lat             Float?
  lng             Float?
  location_name   String?
  description     String
  status          watch_alert_status @default(pending)
  submitted_by    String?            @db.Uuid
  moderated_by    String?            @db.Uuid
  moderation_note String?
  moderated_at    DateTime?          @db.Timestamptz(6)
  evidence_urls   String[]           @default([])
  created_at      DateTime           @default(now()) @db.Timestamptz(6)
  updated_at      DateTime           @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)], map: "idx_watch_alerts_created")
  @@index([plate], map: "idx_watch_alerts_plate")
  @@index([status], map: "idx_watch_alerts_status")
  @@index([type], map: "idx_watch_alerts_type")
  @@index([vin], map: "idx_watch_alerts_vin")
}

enum CaveatSt {
  clear
  caveat
  unknown
}

enum ContribStatus {
  pending
  approved
  rejected
  flagged
}

enum ContribType {
  MILEAGE_RECORD
  DAMAGE_REPORT
  SERVICE_RECORD
  OWNERSHIP_TRANSFER
  LISTING_PROOF
  INSPECTION_RECORD
  IMPORT_DOCUMENT
  THEFT_REPORT
  PHOTO_EVIDENCE
  GENERAL_NOTE
}

enum CorSource {
  user_webview
  admin
}

enum DataStatus {
  found
  not_found
